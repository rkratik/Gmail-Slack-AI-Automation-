# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gmail-slack-automation
DB_NAME=gmail-slack-automation

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Google Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
GOOGLE_FORM_API_KEY=your-google-api-key

# Gmail Configuration
GMAIL_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GMAIL_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...
GMAIL_FROM_EMAIL=noreply@yourcompany.com

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_ID=your-slack-app-id

# OpenAI Configuration (for AI analysis)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=500

# Redis Configuration (for caching and real-time)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://yourdomain.com

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_URL=http://localhost:5000/webhooks

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_AI_ANALYSIS=true
ENABLE_REAL_TIME_NOTIFICATIONS=true
ENABLE_CACHING=true
ENABLE_AUDIT_LOGGING=true

# Security
CORS_ORIGIN=http://localhost:3000
SECURE_COOKIES=false
SESSION_SECRET=your-session-secret-key

# Analytics
ANALYTICS_ENABLED=true
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
